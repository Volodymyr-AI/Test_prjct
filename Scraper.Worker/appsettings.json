{
  "Worker": {
    "Interval": "01:00:00"
  },
  "Scraper": {
    "TargetUrl": "https://finance.yahoo.com/topic/latest-news/",
    "MaxScrollIterations": 60,
    "ScrollDelayMs": 1500,
    "StableScrollThreshold": 3
  },
  "ConnectionStrings": {
    "ClickHouse": "Host=localhost;Port=8123;Database=scraper;Username=default;Password=",
    "Redis": "localhost:6379"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    }
  }
}
